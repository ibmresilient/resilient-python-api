#!/usr/bin/env bash
# Combined pre-commit hook: branch validation + pre-commit framework

# Part 1: Branch name validation
# The branch name must adhere to the format:
# JIRA Type/JIRA Number/Package Name/Brief description

# Example 1: 'epic/SOARAPPS-0000/fn_my_package'
# Example 2: 'story/SOARAPPS-0000/fn_my_package/new_feature'
# Example 3: 'bug/SOARAPPS-0000/fn_my_package/fix_unicode_error'
# Example 4: 'task/SOARAPPS-0000/fn_my_package/update_docs'
# Example 5: 'rebuild/SOARAPPS-0000/ALL'

LC_ALL=C

local_branch="$(git rev-parse --abbrev-ref HEAD)"

valid_branch_regex="^[a-z]+\/INT-[0-9]+\/[a-zA-Z_]+|SOARAPPS-[0-9]+\/[a-zA-Z_]+"

message="INVALID BRANCH NAME. Branch names must adhere to this contract: $valid_branch_regex with the 3rd segment being the package_name. You should rename your branch to a valid name and try again. Example 1: 'story/SOARAPPS-0000/fn_my_package/new_feature'. Example 2: 'epic/SOARAPPS-0000/fn_my_package'"

if [[ ! $local_branch =~ $valid_branch_regex ]] ; then
    echo "$message"
    exit 1
fi

# Part 2: Run pre-commit framework (detect-secrets, etc.)
# Dynamically finds pre-commit in the user's environment

if command -v pre-commit > /dev/null; then
    # Use pre-commit from PATH - works with any Python environment
    exec pre-commit run --hook-stage pre-commit
else
    echo '`pre-commit` not found.  Did you forget to activate your virtualenv?' 1>&2
    echo 'Install with: pip install pre-commit' 1>&2
    exit 1
fi